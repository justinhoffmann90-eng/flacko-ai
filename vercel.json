{
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "functions": {
    "app/api/reports/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/cleanup-grace-periods",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/orb/compute",
      "schedule": "50 19 * * 1-5"
    },
    {
      "path": "/api/cron/sync-discord-roles",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/precompute-backtests",
      "schedule": "0 22 * * 1-5"
    }
  ]
}
